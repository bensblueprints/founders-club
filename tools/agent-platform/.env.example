# Gemini Enterprise Agent Platform — cấu hình (copy file này thành .env)
# SDK google-genai đọc đúng 3 biến này khi chạy qua Vertex/Agent Platform:
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=bt-avatar-studio
GOOGLE_CLOUD_LOCATION=global
# Xác thực: KHÔNG cần API key — SDK tự dùng ADC từ `gcloud auth application-default login`.
