# Local development/test stack. The application automatically uses node-postgres
# for localhost and the Neon HTTP driver for deployed Neon URLs.
DATABASE_URL=postgresql://founders:founders@localhost:55432/founders_club
DB_DRIVER=pg
SESSION_SECRET=local-dev-secret-change-before-sharing
ADMIN_TOKEN=local-admin

PUBLIC_SITE_URL=http://localhost:3000
URL=http://localhost:3000
PORT=3000

# Local seed credentials.
SEED_PW_BEN=LocalAdmin123!
SEED_PW_SAMPLE=LocalMember123!

# Real provider sandbox is the default for local development. Automated tests
# override this with PAYMENTS_ENV=mock. Production must explicitly opt in.
PAYMENTS_ENV=sandbox
PAYMENT_PROVIDERS=airwallex,sepay
# RESEND_API_KEY=
# RESEND_API_KEY must have Full access so it can send email and read final delivery status.
# Do not use the RESEND_WEBHOOK_SECRET value, which starts with whsec_.
# RESEND_WEBHOOK_SECRET=whsec_...
# RESEND_WEBHOOK_URL=
# Set true only after the custom Resend tracking subdomain is verified.
# RESEND_CLICK_TRACKING_ENABLED=false
# FROM_EMAIL=Founders Vietnam <support@foundersvn.com>
# NOTIFY_EMAILS=ben@advancedmarketing.co
# AIRWALLEX_API_KEY=
# AIRWALLEX_CLIENT_ID=
# AIRWALLEX_WEBHOOK_SECRET=
# AIRWALLEX_WEBHOOK_URL=
# DATA_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32
# SEPAY_BANK=MBBank
# SEPAY_ACCOUNT_NUMBER=
# SEPAY_WEBHOOK_SECRET=
# SEPAY_WEBHOOK_URL=
# SEPAY_USD_TO_VND_RATE=26000
# Private production checkout testing. Generate a strong value with:
# openssl rand -hex 32
# Configure the same value locally and in production, then run:
# npm run payments:test-link
# QUICK_RESERVATION_TEST_SECRET=
