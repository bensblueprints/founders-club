# FoundersVN production Netlify env import template.
# Copy to prod.env, fill the blank values, then import prod.env in Netlify.
# Do not commit prod.env after filling real secrets.

# Existing production values may already be configured in Netlify:
# DATABASE_URL=
# SESSION_SECRET=
# ADMIN_TOKEN=
# RESEND_API_KEY=
# AIRWALLEX_API_KEY=
# AIRWALLEX_CLIENT_ID=
# AIRWALLEX_ENV=production
# NOTIFY_EMAILS=
# SLACK_WEBHOOK_URL=
# SUPABASE_SERVICE_KEY=

# Production runtime
PUBLIC_SITE_URL=https://foundersvn.com
URL=https://foundersvn.com
PAYMENTS_ENV=production
PAYMENT_PROVIDERS=airwallex,sepay
FROM_EMAIL=Founders Vietnam <support@foundersvn.com>

# Security
# Generate with: openssl rand -base64 32
DATA_ENCRYPTION_KEY=

# Resend
RESEND_WEBHOOK_SECRET=
RESEND_WEBHOOK_URL=https://foundersvn.com/api/function/resend-webhook

# Airwallex
AIRWALLEX_WEBHOOK_SECRET=
AIRWALLEX_WEBHOOK_URL=https://foundersvn.com/api/function/airwallex-webhook

# SePay
SEPAY_BANK=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_NAME=
SEPAY_WEBHOOK_SECRET=
SEPAY_WEBHOOK_URL=https://foundersvn.com/api/function/sepay-webhook
SEPAY_USD_TO_VND_RATE=26000

# Optional email/community links
WHATSAPP_LINK=
COMMUNITY_LINK=
